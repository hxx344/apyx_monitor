APP_ENV=dev
DATABASE_URL=sqlite:///./data/apyx_monitor.db
COLLECTION_INTERVAL_SECONDS=60
NAV_CURVE_INTERVAL_SECONDS=20
ARBITRAGE_CURVE_GATE_ENABLED=true
ARBITRAGE_CURVE_GATE_MAX_AGE_SECONDS=180
ARBITRAGE_CURVE_GATE_MIN_DEVIATION_PCT=0.5
ARBITRAGE_CURVE_GATE_MIN_CHANGE_PCT=0.2
ARBITRAGE_CURVE_GATE_CHANGE_WINDOW_SECONDS=60
HTTP_TIMEOUT_SECONDS=15
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=change-me
DASHBOARD_SESSION_SECRET=replace-with-a-long-random-secret
DASHBOARD_SESSION_TTL_SECONDS=2592000
FEISHU_WEBHOOK_URL=
